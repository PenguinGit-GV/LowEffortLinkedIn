# LowEffortLinkedIn environment configuration.
# Copy to .env for local dev; set the same variables on the Railway service for prod.
# See docs/SETUP.md for where each value comes from. Never commit a real .env.

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...) — Slack app → Install App → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-replace-me
# Slack app → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=replace-me
# Comma-separated Slack user IDs allowed to run /create-post (e.g. U0123ABCDEF)
MARKETER_SLACK_IDS=U0123ABCDEF
# Comma-separated channel IDs where post cards are broadcast to (e.g. C0123ABCDEF,C0456ABCDEF)
ADVOCACY_CHANNEL_ID=C0123ABCDEF

# ── Database ─────────────────────────────────────────────────────────────────
# Railway → Postgres service → Variables → DATABASE_URL (use the internal URL
# for the deployed app; the public URL for running migrations locally)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── LinkedIn ─────────────────────────────────────────────────────────────────
# LinkedIn developer app → Auth tab → Client ID / Client Secret
LINKEDIN_CLIENT_ID=replace-me
LINKEDIN_CLIENT_SECRET=replace-me
# Must EXACTLY match the redirect URL registered on the LinkedIn app's Auth tab
LINKEDIN_REDIRECT_URI=https://YOUR-APP.up.railway.app/auth/linkedin/callback
# true until LinkedIn product access is approved — shares are simulated, not posted
LINKEDIN_MOCK_MODE=true
# Optional: LinkedIn-Version header (YYYYMM) for the versioned REST API.
# Defaults in code; override if LinkedIn sunsets the default version.
# LINKEDIN_API_VERSION=202506

# ── App secrets (generate your own; do not reuse across environments) ────────
# HMAC key for OAuth state + signed connect links:  openssl rand -base64 32
OAUTH_STATE_SECRET=replace-me
# 32-byte key for AES-256-GCM token encryption:     openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-me

# Optional: cron schedule (UTC) for the daily token-expiry reminder DM.
# REMINDER_CRON=0 9 * * *

# Optional: default sharing window for a new post, in hours (1-720). The
# marketer can override this per post in /create-post.
# DEFAULT_POST_EXPIRY_HOURS=8
# Optional: cron schedule (UTC) for the post-expiry job that removes Share
# buttons once a post's window has passed. Runs often since windows are
# hours-scale, not days-scale.
# POST_EXPIRY_CRON=*/15 * * * *

# ── Server ───────────────────────────────────────────────────────────────────
# Public HTTPS origin of this server (the Railway domain, no trailing slash)
PUBLIC_BASE_URL=https://YOUR-APP.up.railway.app
PORT=3000
NODE_ENV=development

# ── Admin config UI (optional) ────────────────────────────────────────────────
# Manage a subset of the above variables at /admin instead of via Railway.
# See plans/env-var-ui-feature-spec.md. Off by default — most deployments
# won't have set up "Sign in with Slack" yet.
# ADMIN_UI_ENABLED=true
#
# Slack app → OAuth & Permissions → "Sign in with Slack" (OpenID Connect)
# section → Client ID / Client Secret. Required only when ADMIN_UI_ENABLED.
# SLACK_CLIENT_ID=replace-me
# SLACK_CLIENT_SECRET=replace-me
# HMAC key for the admin session cookie:            openssl rand -base64 32
# Deliberately separate from OAUTH_STATE_SECRET so rotating one doesn't log
# out admins or invalidate in-flight LinkedIn connect links.
# ADMIN_SESSION_SECRET=replace-me
